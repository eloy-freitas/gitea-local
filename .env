# Configurações de Usuário do Gitea
USER_UID=1000
USER_GID=1000

# Usando SQLite (muito mais leve para um notebook antigo)
GITEA__database__DB_TYPE=sqlite3

# Ativar o Gitea Actions
GITEA__actions__ENABLED=true

# Configurações de Domínio/Servidor
DOMAIN=notebook-server
SSH_DOMAIN=notebook-server
SSH_PORT=2222
HTTP_PORT=3000

# Token para o Runner do Gitea Actions
# Você vai gerar esse token na interface do Gitea:
# Administração do Site -> Actions -> Runners -> Criar novo Runner
GITEA_RUNNER_REGISTRATION_TOKEN=cole_seu_token_aqui_depois
